rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidView(data) {
      return data.keys().hasAll(['count']) &&
             data.keys().size() == 1 &&
             data.count is int &&
             data.count >= 0;
    }

    // Articles/Posts collection rules
    match /posts/{postId} {
      allow read: if true;
      allow write: if false;
    }

    // Views tracker collection rules
    match /views/{postId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidView(request.resource.data);
      allow update: if isValidId(postId) && isValidView(request.resource.data) &&
                    request.resource.data.count == resource.data.count + 1;
    }
  }
}

